{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repo-Roast Dimension Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["dimension", "score", "summary", "issues", "highlights", "stats"],
  "properties": {
    "dimension": { "$ref": "#/$defs/dimension" },
    "score": { "enum": ["S", "A", "B", "C", "D"] },
    "summary": { "type": "string", "minLength": 1 },
    "issues": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "highlights": {
      "type": "array",
      "items": { "$ref": "#/$defs/highlight" }
    },
    "observations": {
      "type": "array",
      "description": "Unscored items that require more evidence. Observations never enter formal issues or scoring.",
      "items": { "$ref": "#/$defs/observation" }
    },
    "stats": {
      "type": "object",
      "description": "Dimension-specific observed statistics. Values must be JSON scalars or arrays of scalars.",
      "additionalProperties": {
        "anyOf": [
          { "type": ["string", "number", "integer", "boolean", "null"] },
          {
            "type": "array",
            "items": { "type": ["string", "number", "integer", "boolean", "null"] }
          }
        ]
      }
    }
  },
  "$defs": {
    "dimension": {
      "enum": ["architecture", "security", "performance", "readability", "engineering"]
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:)(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$"
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "file",
        "line",
        "title",
        "description",
        "impact",
        "suggestion",
        "pattern"
      ],
      "properties": {
        "severity": { "enum": ["critical", "high", "medium", "low", "info"] },
        "file": { "$ref": "#/$defs/relativePath" },
        "line": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "impact": { "type": "string", "minLength": 1 },
        "suggestion": { "type": "string", "minLength": 1 },
        "pattern": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      }
    },
    "highlight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "title", "description"],
      "properties": {
        "file": { "$ref": "#/$defs/relativePath" },
        "line": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "line", "description", "verification_needed"],
      "properties": {
        "file": { "$ref": "#/$defs/relativePath" },
        "line": { "type": "integer", "minimum": 1 },
        "description": { "type": "string", "minLength": 1 },
        "verification_needed": { "type": "string", "minLength": 1 }
      }
    }
  }
}

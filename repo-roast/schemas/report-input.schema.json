{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repo-Roast Editor Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_profile",
    "reviews",
    "review_errors",
    "requested_dimensions",
    "completed_dimensions",
    "failed_dimensions",
    "skipped_dimensions",
    "flavor",
    "tone"
  ],
  "properties": {
    "project_profile": { "$ref": "scout.schema.json" },
    "reviews": {
      "type": "object",
      "propertyNames": {
        "enum": ["architecture", "security", "performance", "readability", "engineering"]
      },
      "additionalProperties": { "$ref": "review.schema.json" }
    },
    "review_errors": {
      "type": "object",
      "propertyNames": {
        "enum": ["architecture", "security", "performance", "readability", "engineering"]
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["status", "message"],
        "properties": {
          "status": { "enum": ["timeout", "parse_error", "validation_error"] },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "requested_dimensions": { "$ref": "#/$defs/requestedDimensionList" },
    "completed_dimensions": { "$ref": "#/$defs/dimensionList" },
    "failed_dimensions": { "$ref": "#/$defs/dimensionList" },
    "skipped_dimensions": { "$ref": "#/$defs/dimensionList" },
    "flavor": { "enum": ["default", "google", "startup", "oss-maintainer"] },
    "tone": { "enum": ["professional", "sharp", "savage"] }
  },
  "$defs": {
    "dimensionList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["architecture", "security", "performance", "readability", "engineering"]
      }
    },
    "requestedDimensionList": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": ["architecture", "security", "performance", "readability", "engineering"]
      }
    }
  }
}
